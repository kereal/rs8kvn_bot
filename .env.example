# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=123456789
CONTACT_USERNAME=billgates

# 3x-ui Panel Configuration (ONLY used for initial seed when sources table is empty)
# After first run, sources are managed via the database (sources table).
XUI_HOST=http://localhost:2053
XUI_API_TOKEN=your_api_token_here
XUI_INBOUND_ID=1

# Database Configuration
DATABASE_PATH=./data/tgvpn.db

# Logging Configuration
LOG_FILE_PATH=./data/bot.log
LOG_LEVEL=info

# REQUIRED: Base URL for subscription links.
# Constructs full subscription URLs as GLOBAL_SUB_URL + <subscription_id> (e.g. https://vpn.example.com/sub/abc123).
# If left empty, subscription links will be broken.
GLOBAL_SUB_URL=https://vpn.example.com/sub/

# Heartbeat Configuration (optional)
HEARTBEAT_URL=
HEARTBEAT_INTERVAL=300

# Sentry Error Tracking (optional)
# Get your DSN from Better Stack or Sentry dashboard
SENTRY_DSN=

# Health Check Configuration
HEALTH_CHECK_PORT=8880

# Trial & Referral Configuration
SITE_URL=https://vpn.site
TRIAL_DURATION_HOURS=3
TRIAL_RATE_LIMIT=3

# Donation Configuration (optional, uses defaults if not set)
DONATE_CARD_NUMBER=
DONATE_URL=

# API Configuration
# Bearer token for GET /api/v1/subscriptions endpoint
API_TOKEN=

# Proxy Manager Webhook Configuration
# Bearer token for webhook authentication
PROXY_MANAGER_WEBHOOK_SECRET=
# Proxy Manager webhook URL (leave empty to disable webhook)
PROXY_MANAGER_WEBHOOK_URL=

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=123456789
CONTACT_USERNAME=billgates

# 3x-ui Panel Configuration
XUI_HOST=http://localhost:2053
XUI_USERNAME=admin
XUI_PASSWORD=admin_password
XUI_INBOUND_ID=1
XUI_SUB_PATH=sub
# Session max age in minutes. Must match the panel's sessionMaxAge setting (default: 720 = 12h).
XUI_SESSION_MAX_AGE_MINUTES=720

# Database Configuration
DATABASE_PATH=./data/tgvpn.db

# Logging Configuration
LOG_FILE_PATH=./data/bot.log
LOG_LEVEL=info

# Subscription Configuration
TRAFFIC_LIMIT_GB=30

# Heartbeat Configuration (optional)
HEARTBEAT_URL=
HEARTBEAT_INTERVAL=300

# Sentry Error Tracking (optional)
# Get your DSN from Better Stack or Sentry dashboard
SENTRY_DSN=

# Health Check Configuration
HEALTH_CHECK_PORT=8880

# Trial & Referral Configuration
SITE_URL=https://vpn.site
TRIAL_DURATION_HOURS=3
TRIAL_RATE_LIMIT=3

# Donation Configuration (optional, uses defaults if not set)
DONATE_CARD_NUMBER=
DONATE_URL=

# Subscription Proxy Configuration
# Enable/disable extra servers in subscription responses
SUB_EXTRA_SERVERS_ENABLED=true
# Path to file with extra headers and server links.
# Format: header lines (Key: Value) at top, blank line separator, then server links (one per line).
# Lines starting with # are comments.
# Example:
#   X-Custom-Header: some-value
#   X-Another: value
#
#   vless://user@server:443
#   trojan://pass@server:443
SUB_EXTRA_SERVERS_FILE=./data/extra_servers.txt

# API Configuration
# Bearer token for GET /api/v1/subscriptions endpoint
API_TOKEN=

# Proxy Manager Webhook Configuration
# Bearer token for webhook authentication
PROXY_MANAGER_WEBHOOK_SECRET=
# Proxy Manager webhook URL (leave empty to disable webhook)
PROXY_MANAGER_WEBHOOK_URL=

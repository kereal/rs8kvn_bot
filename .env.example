# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=123456789
CONTACT_USERNAME=billgates

# REQUIRED: Base URL for subscription links.
# Constructs full subscription URLs as GLOBAL_SUB_URL + <subscription_id> (e.g. https://vpn.example.com/sub/abc123).
# If left empty, subscription links will be broken.
GLOBAL_SUB_URL=https://vpn.example.com/sub/

# Database Configuration
DATABASE_PATH=./data/tgvpn.db

# Logging Configuration
LOG_FILE_PATH=./data/bot.log
LOG_LEVEL=info

# Subscription /sub/{id} access log. Set empty to disable; startup continues if this file cannot be opened.
SUBSERVER_ACCESS_LOG=./data/subserver.log

# Heartbeat Configuration (optional)
HEARTBEAT_URL=
HEARTBEAT_INTERVAL=300

# Sentry Error Tracking (optional)
# Get your DSN from Better Stack or Sentry dashboard
SENTRY_DSN=

# Health Check Configuration
HEALTH_CHECK_PORT=8880

# Trial & Referral Configuration
SITE_URL=https://vpn.site
TRIAL_DURATION_HOURS=3
TRIAL_RATE_LIMIT=3

# Donation Configuration (optional, uses defaults if not set)
DONATE_CARD_NUMBER=
DONATE_URL=

# Main Menu Product Button (optional)
# Set to a product ID to show a purchase button in the main menu.
# MAIN_MENU_BTN_PRODUCT=1
